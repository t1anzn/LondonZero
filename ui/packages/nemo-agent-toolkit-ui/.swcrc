{
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true,
      "dynamicImport": true
    },
    "transform": {
      "react": {
        "runtime": "automatic"
      }
    },
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "module": {
    "type": "es6"
  },
  "env": {
    "targets": {
      "node": "22"
    }
  },
  "sourceMaps": true
}