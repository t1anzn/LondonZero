{
    "extends": "./tsconfig.json",
    "compilerOptions": {
      "outDir": "./lib",
      "emitDeclarationOnly": true,
      "declaration": true,
      "jsx": "react-jsx",
      "noEmit": false,
      "skipLibCheck": true,
      "noImplicitAny": false,
      "strict": false,
      "noEmitOnError": false
    },
    "include": [
      "lib-src/**/*",
      "pages/**/*",
      "components/**/*",
      "hooks/**/*",
      "utils/**/*",
      "types/**/*",
      "constants/**/*",
      "styles/**/*"
    ],
    "exclude": [
      "node_modules",
      "lib",
      ".next",
      "__tests__",
      "**/*.test.ts",
      "**/*.test.tsx"
    ]
  }