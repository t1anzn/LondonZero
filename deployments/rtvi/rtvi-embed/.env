# Port for RTVI Embed microservice
RTVI_EMBED_PORT=8017

# Enable OTEL Monitoring
RTVI_EMBED_ENABLE_OTEL_MONITORING=false
RTVI_EMBED_OTEL_EXPORTER_OTLP_ENDPOINT=

# Enable Kafka messages
RTVI_EMBED_KAFKA_ENABLED=true
RTVI_EMBED_KAFKA_TOPIC=mdx-embed
RTVI_EMBED_ERROR_MESSAGE_TOPIC=vision-embed-errors
RTVI_EMBED_KAFKA_BOOTSTRAP_SERVERS=

# Set the Huggingface token
#HF_TOKEN=
