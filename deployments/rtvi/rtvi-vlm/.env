# Port for RTVI VLM microservice
RTVI_VLM_PORT=8018

# Enable OTEL Monitoring
RTVI_VLM_ENABLE_OTEL_MONITORING=false
RTVI_VLM_OTEL_EXPORTER_OTLP_ENDPOINT=

# Enable Kafka messages
RTVI_VLM_KAFKA_ENABLED=true
RTVI_VLM_KAFKA_TOPIC=mdx-vlm
RTVI_VLM_KAFKA_INCIDENT_TOPIC=mdx-vlm-incidents
RTVI_VLM_ERROR_MESSAGE_TOPIC=vision-llm-errors

# GPU configuration
RTVI_VLM_NUM_GPUS=1
RTVI_VLM_DEFAULT_NUM_FRAMES_PER_SECOND_OR_FIXED_FRAMES_CHUNK=1
RTVI_VLM_NVIDIA_VISIBLE_DEVICES=all
