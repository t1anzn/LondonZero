# =============================================================================
# DEV-PROFILE-ALERTS ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains environment variables for the developer alerts profile.
# Services: Foundational, VST, NIM, Perception, Analytics, Agents
#
# Profile variants:
# 2d_cv:
#   bp_developer_search
# 2d_vlm:
#   bp_developer_search
# =============================================================================

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# These variables control which services are deployed
# User should modify these based on deployment requirements

# Deployment mode: 2d_cv OR 2d_vlm
MODE=2d_cv

# Blueprint profile: bp_developer_alerts
BP_PROFILE=bp_developer_alerts

# Hardware profile for NIM configuration optimization
# Valid values: H100, L40S, RTXPRO6000BW, DGX-SPARK, IGX-THOR, AGX-THOR, OTHER
HARDWARE_PROFILE=H100

RESERVED_DEVICE_IDS='0'
FIXED_SHARED_DEVICE_IDS=''
RT_CV_DEVICE_ID='0'
RT_VLM_DEVICE_ID='0'
LLM_DEVICE_ID='1'
VLM_DEVICE_ID='1'

# LLM_MODE and VLM_MODE for deployment: local_shared, local, or remote
# For local_shared: requires NGC_CLI_API_KEY, runs LLM and VLM on single GPU
# For local: requires NGC_CLI_API_KEY
# For remote: requires LLM_BASE_URL and VLM_BASE_URL to be configured
LLM_MODE=local_shared
VLM_MODE=local_shared

# LLM options:
# - LLM_NAME: nvidia/nvidia-nemotron-nano-9b-v2
#   LLM_NAME_SLUG: nvidia-nemotron-nano-9b-v2
# - LLM_NAME: nvidia/NVIDIA-Nemotron-Nano-9B-v2-FP8
#   LLM_NAME_SLUG: nvidia-nemotron-nano-9b-v2-fp8
# - LLM_NAME: nvidia/nemotron-3-nano
#   LLM_NAME_SLUG: nemotron-3-nano
# - LLM_NAME: nvidia/llama-3.3-nemotron-super-49b-v1.5
#   LLM_NAME_SLUG: llama-3.3-nemotron-super-49b-v1.5
# - LLM_NAME: openai/gpt-oss-20b
#   LLM_NAME_SLUG: gpt-oss-20b
LLM_NAME=nvidia/nvidia-nemotron-nano-9b-v2
LLM_NAME_SLUG=nvidia-nemotron-nano-9b-v2
LLM_ENV_FILE=''
LLM_BASE_URL=''
LLM_MODEL_TYPE=nim

# VLM options:
# - VLM_NAME: nvidia/cosmos-reason1-7b
#   VLM_NAME_SLUG: cosmos-reason1-7b
# - VLM_NAME: nvidia/cosmos-reason2-8b
#   VLM_NAME_SLUG: cosmos-reason2-8b
# - VLM_NAME: Qwen/Qwen3-VL-8B-Instruct
#   VLM_NAME_SLUG: qwen3-vl-8b-instruct
VLM_NAME=nvidia/cosmos-reason2-8b
VLM_NAME_SLUG=cosmos-reason2-8b
VLM_ENV_FILE=''
VLM_BASE_URL=''
VLM_MODEL_TYPE=nim

# Control when proxy is used
PROXY_MODE='no_proxy'

# Computed compose profiles (DO NOT MODIFY)
COMPOSE_PROFILES=${BP_PROFILE}_${MODE},${BP_PROFILE}_${MODE}_${HARDWARE_PROFILE},${BP_PROFILE}_${MODE}_${PROXY_MODE},llm_${LLM_MODE}_${LLM_NAME_SLUG},vlm_${VLM_MODE}_${VLM_NAME_SLUG}

# =============================================================================
# CORE INFRASTRUCTURE PATHS
# =============================================================================
# Used by: Foundational services, VST, NIM, Perception, Agents
# User MUST modify these paths

# Path to deployments directory
MDX_SAMPLE_APPS_DIR="/path/to/deployments"

# Path to data directory (for models, videos, data logs)
MDX_DATA_DIR="/path/to/metropolis-apps-data"

# Host IP address for networking
HOST_IP='<HOST_IP>'
EXTERNAL_IP="${HOST_IP}"

# =============================================================================
# API KEYS & CREDENTIALS
# =============================================================================

# NGC CLI API Key (REQUIRED for local LLM / VLM deployment)
# Obtain from: https://ngc.nvidia.com/
NGC_CLI_API_KEY=''

# NVIDIA API Key (REQUIRED for build.nvidia.com remote LLM / VLM endpoints)
# Obtain from: https://build.nvidia.com/
NVIDIA_API_KEY=''

# OPENAI API Key (REQUIRED for openai remote LLM / VLM endpoints)
# Obtain from: https://platform.openai.com/
OPENAI_API_KEY=''

# =============================================================================
# ELASTICSEARCH CONFIGURATION
# =============================================================================

# Elasticsearch ILM policy retention period
ELASTICSEARCH_ILM_MIN_AGE=4h

# Maximum number of attempts to connect to Elasticsearch
ELASTICSEARCH_CONNECTION_MAX_ATTEMPTS=20
# =============================================================================
# MESSAGE BROKER CONFIGURATION
# =============================================================================
# Used by: Foundational services, VST, Perception

# Message broker type: kafka or redis
STREAM_TYPE=kafka

# =============================================================================
# HARDWARE & PERCEPTION CONFIGURATION
# =============================================================================
# Used by: Perception and analytics services

# Perception model type
# Valid values: cnn
MODEL_TYPE=cnn

# Perception 2D model name
# Valid values: GDINO
MODEL_NAME_2D="GDINO"

# Perception container image and tag
# For multi-arch: 3.1.0-<version>
# For DGX-SPARK (SBSA): 3.1.0-sbsa-<version>
PERCEPTION_IMAGE="nvcr.io/nvidia/vss-core/vss-rt-cv"
PERCEPTION_TAG="3.1.0"

# Uncomment below Perception Image tag for DGX-SPARK
#PERCEPTION_TAG="3.1.0-sbsa"

# Number of sensors/streams to process
NUM_SENSORS=1

# Custom perception dockerfile prefix. Should be set to 'DGX-SPARK-' when HARDWARE_PROFILE is DGX-SPARK
PERCEPTION_DOCKERFILE_PREFIX=''

# =============================================================================
# NVSTREAMER CONFIGURATION
# =============================================================================
# Used by: nvstreamer-alerts

# Install additional packages for audio, software encoding, file upload
NVSTREAMER_INSTALL_ADDITIONAL_PACKAGES=true

# Nvstreamer HTTP port
NVSTREAMER_HTTP_PORT=31000

# =============================================================================
# DOCKER COMPOSE CONFIGURATION
# =============================================================================

# Project name for volume naming (DO NOT MODIFY)
COMPOSE_PROJECT_NAME=mdx

# =============================================================================
# VLM-AS-VERIFIER CONFIGURATION
# =============================================================================
# Used by: alert-bridge service

# Custom vlm-as-verifier config yml prefix. Should be set to 'EDGE-LOCAL-VLM-' when HARDWARE_PROFILE is DGX-SPARK, IGX-THOR, or AGX-THOR and VLM_MODE is not remote
VLM_AS_VERIFIER_CONFIG_FILE_PREFIX=''

VLM_AS_VERIFIER_CONFIG_FILE=${MDX_SAMPLE_APPS_DIR}/developer-workflow/dev-profile-alerts/vlm-as-verifier/configs/${VLM_AS_VERIFIER_CONFIG_FILE_PREFIX}config.yml
VLM_AS_VERIFIER_ALERT_TYPE_CONFIG_FILE=${MDX_SAMPLE_APPS_DIR}/developer-workflow/dev-profile-alerts/vlm-as-verifier/configs/alert_type_config.json

# =============================================================================
# NIM CONFIGURATION
# =============================================================================
# Used by: vss-agent, alert-bridge

# LLM Configuration
LLM_PORT=30081

# VLM Configuration
VLM_PORT=30082

VLM_NIM_KVCACHE_PERCENT="0.7"
# Custom model weights (optional)
# VLM_CUSTOM_WEIGHTS=""

# =============================================================================
# VSS AGENT CONFIGURATION
# =============================================================================
# Used by: vss-agent, vss-va-mcp, vss-ui services

# VSS Agent Core
VSS_AGENT_VERSION=3.1.0
VSS_AGENT_CONFIG_FILE=./deployments/developer-workflow/dev-profile-alerts/vss-agent/configs/config.yml
VSS_AGENT_HOST=0.0.0.0
VSS_AGENT_PORT=8000

STREAM_MODE=other

# Video Analysis MCP URL
VIDEO_ANALYSIS_MCP_URL=http://${HOST_IP}:9901

# VSS Video Analysis MCP Server
VSS_VA_MCP_CONFIG_FILE=./deployments/developer-workflow/dev-profile-alerts/vss-agent/configs/va_mcp_server_config.yml
VSS_VA_MCP_PORT=9901

# VSS Agent Templates
VSS_AGENT_TEMPLATE_PATH=./deployments/developer-workflow/dev-profile-alerts/vss-agent/templates
VSS_AGENT_TEMPLATE_NAME=incident_report_template.md

# Video Analytics API Port
MDX_PORT=8081

# =============================================================================
# RTVI CONFIGURATION
# =============================================================================
# Used by: RTVI services (for 2d_vlm mode)

# RTVI VLM Container Image tag
# For multi-arch: 3.0.0-<version>
# For DGX-SPARK (SBSA): 3.0.0-<version>-sbsa

# RTVI VLM Container Image tags for x86 and THOR
RTVI_VLM_IMAGE_TAG="3.1.0"

# Uncomment below RTVI VLM Container Image tag for DGX-SPARK
#RTVI_VLM_IMAGE_TAG="3.1.0-sbsa"

RTVI_VLM_BASE_URL=http://${HOST_IP}:8018
RTVI_VLM_ENDPOINT=http://${HOST_IP}:30082/v1
RTVI_VLM_OPENAI_MODEL_DEPLOYMENT_NAME=${VLM_NAME}
RTVI_VLM_MODEL_TO_USE=openai-compat
RTVI_VLLM_GPU_MEMORY_UTILIZATION=''
RTVI_VLM_MODEL_PATH='ngc:nim/nvidia/cosmos-reason2-8b:hf-1208'

# RTVI VLM Kafka Configuration
RTVI_VLM_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
RTVI_VLM_KAFKA_INCIDENT_TOPIC=mdx-vlm-incidents

# RTVI VLM input dimensions and frame rate (set by dev-profile.sh for DGX-SPARK, IGX-THOR, AGX-THOR only; not set on other platforms)
# RTVI_VLM_INPUT_WIDTH=860
# RTVI_VLM_INPUT_HEIGHT=467
# RTVI_VLM_DEFAULT_NUM_FRAMES_PER_SECOND_OR_FIXED_FRAMES_CHUNK=20

# =============================================================================
# VST (VIDEO STORAGE TOOL) CONFIGURATION
# =============================================================================
# Used by: vss-agent, vss-ui

# VST Base Configuration
VST_PORT=30888
VST_EXTERNAL_URL=http://${EXTERNAL_IP}:${VST_PORT}
VST_INTERNAL_URL=http://${HOST_IP}:${VST_PORT}

# VST MCP Configuration
VST_MCP_PORT=8001
VST_MCP_URL=http://${HOST_IP}:${VST_MCP_PORT}

# VST Adaptor type
# Valid values: vst_rtsp, milestone_onvif
VST_ADAPTOR=vst_rtsp

# VST Image tags for common all platforms
VST_MCP_IMAGE_TAG="3.1.0"

# VST Image tags for x86 and DGX-THOR
VST_STREAM_PROCESSOR_IMAGE_TAG="3.1.0"
VST_SENSOR_IMAGE_TAG="3.1.0"
NVSTREAMER_IMAGE_TAG="3.1.0"

# Uncomment below VST Image tags for DGX-SPARK
# VST_STREAM_PROCESSOR_IMAGE_TAG="3.1.0-sbsa"
# VST_SENSOR_IMAGE_TAG="3.1.0-sbsa"
# NVSTREAMER_IMAGE_TAG="3.1.0-sbsa"

# =============================================================================
# AGENT STORAGE & REPORT CONFIGURATION
# =============================================================================
# Used by: vss-agent

VSS_ES_PORT=9200

# Object store type: local_object_store (in-memory, not persisted) or s3
VSS_AGENT_OBJECT_STORE_TYPE=local_object_store

# Base URL for report access
VSS_AGENT_REPORTS_BASE_URL=http://${EXTERNAL_IP}:${VSS_AGENT_PORT}/static/
VSS_AGENT_EXTERNAL_URL=http://${EXTERNAL_IP}:${VSS_AGENT_PORT}

# =============================================================================
# PHOENIX TELEMETRY CONFIGURATION
# =============================================================================
# Used by: vss-agent

PHOENIX_ENDPOINT=http://${HOST_IP}:6006

# =============================================================================
# AGENT UI CONFIGURATION
# =============================================================================
# Used by: vss-ui

NEXT_PUBLIC_APP_TITLE="VSS BLUEPRINT"
NEXT_PUBLIC_APP_SUBTITLE="Vision (Alerts)"
NEXT_PUBLIC_WORKFLOW="VSS Agent"
NEXT_PUBLIC_ENABLE_CHAT_TAB=true
NEXT_PUBLIC_CHAT_API_CUSTOM_AGENT_PARAMS_JSON={"params":[{"name":"llm_reasoning","label":"LLM Reasoning","type":"boolean","default-value":false,"changeable":true,"tooltip-info":""},{"name":"vlm_reasoning","label":"VLM Reasoning","type":"boolean","default-value":false,"changeable":true,"tooltip-info":""}]}
NEXT_PUBLIC_CHAT_UPLOAD_FILE_ENABLE=false
NEXT_PUBLIC_ENABLE_ALERTS_TAB=true
NEXT_PUBLIC_ALERTS_TAB_VERIFIED_FLAG_DEFAULT=true
NEXT_PUBLIC_ENABLE_DASHBOARD_TAB=false
NEXT_PUBLIC_ENABLE_MAP_TAB=false
NEXT_PUBLIC_ENABLE_VIDEO_MANAGEMENT_TAB=true
NEXT_PUBLIC_VIDEO_MANAGEMENT_TAB_ADD_RTSP_ENABLE=true
NEXT_PUBLIC_VIDEO_MANAGEMENT_VIDEO_UPLOAD_ENABLE=false
NEXT_PUBLIC_ENABLE_SEARCH_TAB=false
