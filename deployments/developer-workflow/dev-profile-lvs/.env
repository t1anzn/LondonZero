# =============================================================================
# DEV-PROFILE-LVS ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains environment variables for the developer LVS profile.
# Services: Foundational, VST, NIM, LVS, Agents
#
# Profile variants:
# 2d:
#   bp_developer_lvs
# =============================================================================

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# These variables control which services are deployed
# User should modify these based on deployment requirements

# Deployment mode: 2d
MODE=2d

# Blueprint profile: bp_developer_lvs
BP_PROFILE=bp_developer_lvs

# Hardware profile for NIM configuration optimization
# Valid values: H100, L40S, RTXPRO6000BW, DGX-SPARK, IGX-THOR, AGX-THOR, OTHER
HARDWARE_PROFILE=H100

RESERVED_DEVICE_IDS=''
FIXED_SHARED_DEVICE_IDS=''
LLM_DEVICE_ID='0'
VLM_DEVICE_ID='0'

# LLM_MODE and VLM_MODE for deployment: local_shared, local, or remote
# For local_shared: requires NGC_CLI_API_KEY, runs LLM and VLM on single GPU
# For local: requires NGC_CLI_API_KEY
# For remote: requires LLM_BASE_URL and VLM_BASE_URL to be configured
LLM_MODE=local_shared
VLM_MODE=local_shared

# LLM options:
# - LLM_NAME: nvidia/nvidia-nemotron-nano-9b-v2
#   LLM_NAME_SLUG: nvidia-nemotron-nano-9b-v2
# - LLM_NAME: nvidia/NVIDIA-Nemotron-Nano-9B-v2-FP8
#   LLM_NAME_SLUG: nvidia-nemotron-nano-9b-v2-fp8
# - LLM_NAME: nvidia/nemotron-3-nano
#   LLM_NAME_SLUG: nemotron-3-nano
# - LLM_NAME: nvidia/llama-3.3-nemotron-super-49b-v1.5
#   LLM_NAME_SLUG: llama-3.3-nemotron-super-49b-v1.5
# - LLM_NAME: openai/gpt-oss-20b
#   LLM_NAME_SLUG: gpt-oss-20b
LLM_NAME=nvidia/nvidia-nemotron-nano-9b-v2
LLM_NAME_SLUG=nvidia-nemotron-nano-9b-v2
LLM_ENV_FILE=''
LLM_BASE_URL=''
LLM_MODEL_TYPE=nim

# VLM options:
# - VLM_NAME: nvidia/cosmos-reason1-7b
#   VLM_NAME_SLUG: cosmos-reason1-7b
# - VLM_NAME: nvidia/cosmos-reason2-8b
#   VLM_NAME_SLUG: cosmos-reason2-8b
# - VLM_NAME: Qwen/Qwen3-VL-8B-Instruct
#   VLM_NAME_SLUG: qwen3-vl-8b-instruct
VLM_NAME=nvidia/cosmos-reason2-8b
VLM_NAME_SLUG=cosmos-reason2-8b
VLM_ENV_FILE=''
VLM_BASE_URL=''
VLM_MODEL_TYPE=nim

# Control when proxy is used
PROXY_MODE='no_proxy'

# Computed compose profiles (DO NOT MODIFY)
COMPOSE_PROFILES=${BP_PROFILE}_${MODE},${BP_PROFILE}_${MODE}_${PROXY_MODE},llm_${LLM_MODE}_${LLM_NAME_SLUG},vlm_${VLM_MODE}_${VLM_NAME_SLUG}

# =============================================================================
# CORE INFRASTRUCTURE PATHS
# =============================================================================
# Used by: Foundational services, VST, NIM, LVS, Agents
# User MUST modify these paths

# Path to deployments directory
MDX_SAMPLE_APPS_DIR="/path/to/deployments"

# Path to data directory (for models, videos, data logs)
MDX_DATA_DIR="/path/to/metropolis-apps-data"

# Host IP address for networking
HOST_IP='<HOST_IP>'
EXTERNAL_IP="${HOST_IP}"

# =============================================================================
# API KEYS & CREDENTIALS
# =============================================================================

# NGC CLI API Key (REQUIRED for local LLM / VLM deployment)
# Obtain from: https://ngc.nvidia.com/
NGC_CLI_API_KEY=''

# NVIDIA API Key (REQUIRED for build.nvidia.com remote LLM / VLM endpoints)
# Obtain from: https://build.nvidia.com/
NVIDIA_API_KEY=''

# OPENAI API Key (REQUIRED for openai remote LLM / VLM endpoints)
# Obtain from: https://platform.openai.com/
OPENAI_API_KEY=''

# =============================================================================
# ELASTICSEARCH CONFIGURATION
# =============================================================================

# Elasticsearch ILM policy retention period
ELASTICSEARCH_ILM_MIN_AGE=4h

# Maximum number of attempts to connect to Elasticsearch
ELASTICSEARCH_CONNECTION_MAX_ATTEMPTS=20

# =============================================================================
# MESSAGE BROKER CONFIGURATION
# =============================================================================
# Used by: Foundational services, VST

# Message broker type: kafka or redis
STREAM_TYPE=kafka

# =============================================================================
# DOCKER COMPOSE CONFIGURATION
# =============================================================================

# Project name for volume naming (DO NOT MODIFY)
COMPOSE_PROJECT_NAME=mdx

# =============================================================================
# NIM CONFIGURATION
# =============================================================================
# Used by: vss-agent

# LLM Configuration
LLM_PORT=30081

# VLM Configuration
VLM_PORT=30082

VLM_NIM_KVCACHE_PERCENT="0.7"
# Custom model weights (optional)
# VLM_CUSTOM_WEIGHTS=""

# Evaluation LLM Judge
EVAL_LLM_JUDGE_NAME=${LLM_NAME}
EVAL_LLM_JUDGE_BASE_URL=${LLM_BASE_URL}

# =============================================================================
# VSS AGENT CONFIGURATION
# =============================================================================
# Used by: vss-agent, vss-ui services

# VSS Agent Core
VSS_AGENT_VERSION=3.1.0
VSS_AGENT_CONFIG_FILE=./deployments/developer-workflow/dev-profile-lvs/vss-agent/configs/config.yml
VSS_AGENT_HOST=0.0.0.0
VSS_AGENT_PORT=8000

STREAM_MODE=other

# LVS Backend URL
LVS_BACKEND_URL=http://${HOST_IP}:38111

# =============================================================================
# VST (VIDEO STORAGE TOOL) CONFIGURATION
# =============================================================================
# Used by: vss-agent, vss-ui

# VST Base Configuration
VST_PORT=30888
VST_EXTERNAL_URL=http://${EXTERNAL_IP}:${VST_PORT}
VST_INTERNAL_URL=http://${HOST_IP}:${VST_PORT}

# VST MCP Configuration
VST_MCP_PORT=8001
VST_MCP_URL=http://${HOST_IP}:${VST_MCP_PORT}

# VST Adaptor type
# Valid values: vst_rtsp, milestone_onvif
VST_ADAPTOR=vst_rtsp

# VST Image tags for common all platforms
VST_MCP_IMAGE_TAG="3.1.0"

# VST Image tags for x86 and DGX-THOR
VST_STREAM_PROCESSOR_IMAGE_TAG="3.1.0"
VST_SENSOR_IMAGE_TAG="3.1.0"
NVSTREAMER_IMAGE_TAG="3.1.0"

# Uncomment below VST Image tags for DGX-SPARK
# VST_STREAM_PROCESSOR_IMAGE_TAG="3.1.0-sbsa"
# VST_SENSOR_IMAGE_TAG="3.1.0-sbsa"
# NVSTREAMER_IMAGE_TAG="3.1.0-sbsa"

# =============================================================================
# AGENT STORAGE & REPORT CONFIGURATION
# =============================================================================
# Used by: vss-agent

# Object store type: local_object_store (in-memory, not persisted) or s3
VSS_AGENT_OBJECT_STORE_TYPE=local_object_store

# Base URL for report access
VSS_AGENT_REPORTS_BASE_URL=http://${EXTERNAL_IP}:${VSS_AGENT_PORT}/static/
VSS_AGENT_EXTERNAL_URL=http://${EXTERNAL_IP}:${VSS_AGENT_PORT}

# =============================================================================
# PHOENIX TELEMETRY CONFIGURATION
# =============================================================================
# Used by: vss-agent

PHOENIX_ENDPOINT=http://${HOST_IP}:6006

# =============================================================================
# AGENT UI CONFIGURATION
# =============================================================================
# Used by: vss-ui

NEXT_PUBLIC_APP_TITLE="VSS BLUEPRINT"
NEXT_PUBLIC_APP_SUBTITLE="Vision (LVS)"
NEXT_PUBLIC_WORKFLOW="VSS Agent"
NEXT_PUBLIC_ENABLE_CHAT_TAB=true
NEXT_PUBLIC_CHAT_API_CUSTOM_AGENT_PARAMS_JSON={"params":[{"name":"llm_reasoning","label":"LLM Reasoning","type":"boolean","default-value":false,"changeable":true,"tooltip-info":""},{"name":"vlm_reasoning","label":"VLM Reasoning","type":"boolean","default-value":false,"changeable":true,"tooltip-info":""}]}
NEXT_PUBLIC_CHAT_UPLOAD_FILE_ENABLE=true
NEXT_PUBLIC_WEB_SOCKET_DEFAULT_ON=true
NEXT_PUBLIC_ENABLE_ALERTS_TAB=false
NEXT_PUBLIC_ENABLE_SEARCH_TAB=false
NEXT_PUBLIC_ENABLE_DASHBOARD_TAB=true
NEXT_PUBLIC_ENABLE_MAP_TAB=false
NEXT_PUBLIC_ENABLE_VIDEO_MANAGEMENT_TAB=true
NEXT_PUBLIC_VIDEO_MANAGEMENT_TAB_ADD_RTSP_ENABLE=false


# =============================================================================
# LVS (LONG VIDEO SUMMARIZATION) CONFIGURATION
# =============================================================================
# Used by: LVS service

# LVS Image name
LVS_IMAGE="nvcr.io/nvidia/vss-core/vss-long-video-summarization"

# LVS Image tags for x86 and DGX-THOR
LVS_TAG="3.1.0"

# Uncomment below LVS Image tags for DGX-SPARK
# LVS_TAG="3.1.0-sbsa"
