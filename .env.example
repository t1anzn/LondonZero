# Copy to .env and fill in values — never commit .env

# NVIDIA API (build.nvidia.com → get API key)
NVIDIA_API_KEY=nvapi-...

# Mapillary (mapillary.com/developer)
MAPILLARY_ACCESS_TOKEN=...

# ElevenLabs (stretch goal — voice interaction)
ELEVENLABS_API_KEY=...

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
